<Window x:Class="SistemaGestionProyectos2.Views.DriveV2Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IMA Drive"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowDrop="True" AllowsTransparency="False">

    <Window.Resources>
        <!-- ============================================= -->
        <!-- BRUSHES                                       -->
        <!-- ============================================= -->
        <SolidColorBrush x:Key="PrimaryBrush"       Color="#1D4ED8"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush"   Color="#1E40AF"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush"    Color="#1E3A8A"/>
        <SolidColorBrush x:Key="PrimaryLightBrush"   Color="#3B82F6"/>
        <SolidColorBrush x:Key="BackgroundBrush"     Color="#F8FAFC"/>
        <SolidColorBrush x:Key="CardBgBrush"         Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ThemeBorderBrush"    Color="#E2E8F0"/>
        <SolidColorBrush x:Key="BorderLightBrush"    Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"    Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush"  Color="#475569"/>
        <SolidColorBrush x:Key="TextMutedBrush"      Color="#64748B"/>
        <SolidColorBrush x:Key="TextLightBrush"      Color="#94A3B8"/>
        <SolidColorBrush x:Key="SlateLight"          Color="#CBD5E1"/>
        <SolidColorBrush x:Key="HoverBgBrush"        Color="#F8FAFC"/>
        <SolidColorBrush x:Key="ActiveBgBrush"       Color="#EFF6FF"/>
        <SolidColorBrush x:Key="DestructiveBrush"    Color="#EF4444"/>
        <SolidColorBrush x:Key="DestructiveBgBrush"  Color="#FEF2F2"/>
        <SolidColorBrush x:Key="DestructiveHoverBrush" Color="#FEE2E2"/>

        <!-- Semantic tokens -->
        <SolidColorBrush x:Key="SuccessBrush"        Color="#10B981"/>
        <SolidColorBrush x:Key="SuccessBgBrush"      Color="#F0FDF4"/>
        <SolidColorBrush x:Key="WarningBrush"        Color="#F59E0B"/>
        <SolidColorBrush x:Key="WarningBgBrush"      Color="#FFFBEB"/>
        <SolidColorBrush x:Key="DangerBrush"         Color="#EF4444"/>
        <SolidColorBrush x:Key="DangerBgBrush"       Color="#FEF2F2"/>
        <SolidColorBrush x:Key="InfoBrush"           Color="#3B82F6"/>
        <SolidColorBrush x:Key="InfoBgBrush"         Color="#EFF6FF"/>

        <!-- Shared shadow effect -->
        <DropShadowEffect x:Key="CardShadow" Color="#1E293B" BlurRadius="16"
                           ShadowDepth="4" Opacity="0.08" Direction="270"/>

        <!-- Spinner animation -->
        <Storyboard x:Key="SpinnerStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SpinnerRotation"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:1"/>
        </Storyboard>
        <Storyboard x:Key="CtxSpinnerStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="CtxSpinnerRotation"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:1"/>
        </Storyboard>

        <!-- ============================================= -->
        <!-- CONTEXT MENU + TOOLTIP STYLES (P1, P9)        -->
        <!-- ============================================= -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="4"
                                Effect="{StaticResource CardShadow}">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bg" Background="Transparent"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="{TemplateBinding Background}" Height="{TemplateBinding Height}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                Effect="{StaticResource CardShadow}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================= -->
        <!-- BUTTON STYLES                                 -->
        <!-- ============================================= -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <SolidColorBrush x:Name="borderBg" Color="#1D4ED8"/>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard><ColorAnimation Storyboard.TargetName="borderBg" Storyboard.TargetProperty="Color" To="#1E40AF" Duration="0:0:0.1"/></Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard><ColorAnimation Storyboard.TargetName="borderBg" Storyboard.TargetProperty="Color" To="#1D4ED8" Duration="0:0:0.15"/></Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard><ColorAnimation Storyboard.TargetName="borderBg" Storyboard.TargetProperty="Color" To="#1E3A8A" Duration="0:0:0.05"/></Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="border" Property="Opacity" Value="0.5"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <SolidColorBrush x:Name="borderBg" Color="#F8FAFC"/>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard><ColorAnimation Storyboard.TargetName="borderBg" Storyboard.TargetProperty="Color" To="#E2E8F0" Duration="0:0:0.1"/></Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard><ColorAnimation Storyboard.TargetName="borderBg" Storyboard.TargetProperty="Color" To="#F8FAFC" Duration="0:0:0.15"/></Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard><ColorAnimation Storyboard.TargetName="borderBg" Storyboard.TargetProperty="Color" To="#CBD5E1" Duration="0:0:0.05"/></Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DestructiveButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DangerBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#FEE2E2"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="border" Property="Background" Value="#FECACA"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="border" Property="Opacity" Value="0.5"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#F1F5F9"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1D4ED8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="content" Property="TextBlock.Foreground" Value="#1E40AF"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="content" Property="TextBlock.Foreground" Value="#94A3B8"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="content" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                                <Setter TargetName="content" Property="TextBlock.Foreground" Value="#475569"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="border" Property="Background" Value="#F1F5F9"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="border" Property="Opacity" Value="0.5"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ViewToggleButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#F1F5F9"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="256"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================= -->
        <!-- SIDEBAR                                       -->
        <!-- ============================================= -->
        <Border Grid.Column="0" Background="White"
                BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Cache local (always visible, above storage) -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="0,1,0,0"
                        Padding="16,8">
                    <Grid>
                        <TextBlock x:Name="LocalCacheLabel" Text="" FontSize="10"
                                   Foreground="{StaticResource TextLightBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ClearCacheBtn" Text="Limpiar" FontSize="10"
                                   Foreground="{StaticResource PrimaryBrush}" Cursor="Hand"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   MouseLeftButtonDown="ClearCache_Click"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>
                <!-- Storage -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="0,1,0,0"
                        Padding="16">
                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Almacenamiento" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="1" x:Name="StorageLabel" Text="0 B de 10 GB" FontSize="12" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="8,0,0,0"/>
                            </Grid>
                            <Border Height="8" CornerRadius="4" Background="{StaticResource ThemeBorderBrush}" ClipToBounds="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="StorageFillCol" Width="1*"/>
                                        <ColumnDefinition x:Name="StorageEmptyCol" Width="99*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" CornerRadius="4">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                <GradientStop Color="#1D4ED8" Offset="0"/>
                                                <GradientStop Color="#3B82F6" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="StorageAvailLabel" Text="10 GB disponibles"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16">
                        <StackPanel x:Name="NavPanel"/>

                        <TextBlock Text="FILTRAR POR TIPO" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="12,24,0,12"/>
                        <StackPanel x:Name="FilterPanel"/>

                        <!-- V3-B: Actividad -->
                        <Border x:Name="ActivitySection" Margin="0,16,0,0">
                            <StackPanel>
                                <Border x:Name="ActivityHeader" Cursor="Hand" Margin="12,0,0,8"
                                        MouseLeftButtonDown="ActivityHeader_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="ACTIVIDAD" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ActivityChevron" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="10" Foreground="{StaticResource TextLightBrush}"
                                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                                   RenderTransformOrigin="0.5,0.5">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform x:Name="ActivityChevronRotation" Angle="90"/>
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <StackPanel x:Name="ActivityPanel"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ============================================= -->
        <!-- MAIN CONTENT                                  -->
        <!-- ============================================= -->
        <Grid Grid.Column="1" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid Margin="24,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1D4ED8" Offset="0"/>
                                    <GradientStop Color="#3B82F6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="IMA" Foreground="White" FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="IMA Drive" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Gestion de archivos" FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1" Margin="32,0" Background="{StaticResource BackgroundBrush}"
                            BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="1"
                            CornerRadius="8" MaxWidth="640">
                        <Grid>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{StaticResource TextLightBrush}"
                                       VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                            <TextBlock x:Name="SearchPlaceholder"
                                       Text="Buscar archivos, carpetas y ordenes..."
                                       FontSize="14" Foreground="{StaticResource TextLightBrush}"
                                       VerticalAlignment="Center" Margin="36,0,12,0" IsHitTestVisible="False"/>
                            <TextBox x:Name="SearchBox" BorderThickness="0" Background="Transparent"
                                     FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"
                                     VerticalAlignment="Center" Padding="36,10,12,10"
                                     TextChanged="SearchBox_TextChanged"/>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8" Padding="4" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="GridViewBtn" Style="{StaticResource ViewToggleButton}" Click="GridView_Click">
                                    <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                </Button>
                                <Button x:Name="ListViewBtn" Style="{StaticResource ViewToggleButton}" Click="ListView_Click">
                                    <TextBlock Text="&#xEA37;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </Border>
                        <Button x:Name="RefreshButton" Click="RefreshButton_Click" ToolTip="Actualizar"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Actualizar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Click="NewFolder_Click" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Nueva carpeta" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource PrimaryButton}" Click="Upload_Click" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Subir archivo" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Click="CloseWindow_Click" ToolTip="Volver al menu principal">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Volver" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- BREADCRUMB -->
            <Border Grid.Row="1" Background="White"
                    BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="0,0,0,1" Padding="24,12">
                <Grid>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="BreadcrumbPanel" Orientation="Horizontal"/>
                    </ScrollViewer>
                    <TextBlock x:Name="StatusText" Text="" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"/>
                </Grid>
            </Border>

            <!-- SELECTION BANNER -->
            <Border x:Name="SelectionBanner" Grid.Row="2" Background="{StaticResource WarningBgBrush}"
                    BorderBrush="{StaticResource WarningBrush}" BorderThickness="0,0,0,2"
                    Padding="24,10" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SelectionBannerText" FontSize="14" Foreground="#92400E"
                               VerticalAlignment="Center" Text="Seleccione una carpeta para vincular"/>
                    <Button x:Name="LinkThisFolderButton" Style="{StaticResource PrimaryButton}"
                            Content="Vincular esta carpeta"
                            Margin="20,0,0,0" Click="LinkThisFolder_Click"
                            Padding="12,6"/>
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="Cancelar" Margin="10,0,0,0" Click="CancelSelection_Click"
                            Padding="12,6"/>
                </StackPanel>
            </Border>

            <!-- MULTI-SELECT ACTION BAR -->
            <Border x:Name="MultiSelectBar" Grid.Row="2" Background="{StaticResource ActiveBgBrush}"
                    BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,0,0,2"
                    Padding="24,8" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="MultiSelectText" FontSize="14" FontWeight="Medium"
                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource SecondaryButton}" Click="MultiSelectDownload_Click"
                            Margin="20,0,0,0" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Descargar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DestructiveButton}" Click="MultiSelectDelete_Click"
                            Margin="8,0,0,0" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Eliminar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource LinkButton}" Click="MultiSelectClear_Click"
                            Margin="16,0,0,0" Padding="8,6">
                        <TextBlock Text="Cancelar" FontSize="13"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- CONTENT AREA -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24">
                    <Button x:Name="BackToFoldersBtn" Style="{StaticResource LinkButton}"
                            Click="BackToFolders_Click" Visibility="Collapsed"
                            HorizontalAlignment="Left" Margin="0,0,0,8">
                        <TextBlock>
                            <Run Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                            <Run Text=" Volver a carpetas"/>
                        </TextBlock>
                    </Button>
                    <TextBlock x:Name="SectionTitle" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="SectionSubtitle" FontSize="14"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,24"/>
                    <ContentControl x:Name="ContentHost"/>

                    <!-- Empty state -->
                    <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" Margin="0,80,0,0" Visibility="Collapsed">
                        <Border Width="80" Height="80" CornerRadius="40"
                                Background="{StaticResource ActiveBgBrush}"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="32" Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="EmptyStateTitle" Text="Carpeta vacia" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="EmptyStateSubtitle" Text="Crea una carpeta o sube un archivo para comenzar"
                                   FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <StackPanel x:Name="EmptyStateActions" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Button Style="{StaticResource PrimaryButton}" Content="Subir archivos"
                                    Click="Upload_Click" Padding="16,8" Margin="0,0,8,0"/>
                            <Button Style="{StaticResource SecondaryButton}" Content="Nueva carpeta"
                                    Click="NewFolder_Click" Padding="16,8"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Loading spinner (P2) -->
                    <StackPanel x:Name="LoadingPanel" HorizontalAlignment="Center"
                                VerticalAlignment="Center" Margin="0,80,0,0" Visibility="Collapsed">
                        <Border Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Border x:Name="SpinnerBorder" Width="48" Height="48"
                                    BorderBrush="{StaticResource PrimaryBrush}"
                                    BorderThickness="3" CornerRadius="24"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.OpacityMask>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF000000" Offset="0"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.OpacityMask>
                                <Border.RenderTransform>
                                    <RotateTransform x:Name="SpinnerRotation"/>
                                </Border.RenderTransform>
                            </Border>
                        </Border>
                        <TextBlock Text="Cargando archivos..." FontSize="14"
                                   Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- MEJORA-6: Context download overlay with dim background -->
            <Grid x:Name="ContextDownloadOverlay" Grid.Row="3" Visibility="Collapsed">
                <!-- Dim background -->
                <Border Background="#0F172A" Opacity="0.4"/>
                <!-- Modal card -->
                <Border Background="White" CornerRadius="16"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Padding="36,32" MinWidth="380"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Cloud icon -->
                        <Border Width="52" Height="52" CornerRadius="26"
                                Background="#EFF6FF" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Title -->
                        <TextBlock x:Name="CtxDownloadTitle" Text="Preparando ensamble..."
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <!-- Status text -->
                        <TextBlock x:Name="CtxDownloadStatus" Text="Descargando archivos de contexto"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <!-- Spinner + Progress bar -->
                        <Grid Width="300">
                            <ProgressBar x:Name="CtxProgressBar" Height="8"
                                         Minimum="0" Maximum="100" Value="0"
                                         Foreground="{StaticResource PrimaryBrush}"
                                         Background="#E2E8F0">
                                <ProgressBar.Resources>
                                    <Style TargetType="ProgressBar">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ProgressBar">
                                                    <Border CornerRadius="4" Background="{TemplateBinding Background}" ClipToBounds="True">
                                                        <Border x:Name="PART_Indicator" CornerRadius="4"
                                                                Background="{TemplateBinding Foreground}"
                                                                HorizontalAlignment="Left"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ProgressBar.Resources>
                            </ProgressBar>
                        </Grid>
                        <!-- Spinner + percent -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                            <Border Width="16" Height="16" Margin="0,0,6,0">
                                <Border Width="16" Height="16"
                                        BorderBrush="{StaticResource PrimaryBrush}"
                                        BorderThickness="2" CornerRadius="8"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.OpacityMask>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF000000" Offset="0"/>
                                            <GradientStop Color="#00000000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.OpacityMask>
                                    <Border.RenderTransform>
                                        <RotateTransform x:Name="CtxSpinnerRotation"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Border>
                            <TextBlock x:Name="CtxDownloadPercent" Text="0%"
                                       FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Cancel button -->
                        <Button x:Name="CtxCancelBtn" Style="{StaticResource SecondaryButton}"
                                Padding="20,9" Margin="0,18,0,0"
                                FontSize="13" HorizontalAlignment="Center"
                                Click="CtxCancel_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Cancelar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- V3-E: SYNC STATUS BAR -->
            <Border x:Name="SyncStatusBar" Grid.Row="4" Background="#EFF6FF"
                    BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,1,0,0"
                    Padding="24,8" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SyncStatusIcon" Text="&#xE895;"
                               FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource PrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="SyncStatusText" Text="" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button x:Name="SyncRetryBtn" Style="{StaticResource SecondaryButton}"
                            Click="SyncRetry_Click" Margin="16,0,0,0" Padding="12,4"
                            Visibility="Collapsed">
                        <TextBlock Text="Reintentar" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Border>

        </Grid>



        <!-- FULLSCREEN IMAGE OVERLAY (V3-A) -->
        <Border x:Name="ImageOverlay" Grid.ColumnSpan="2" Panel.ZIndex="80"
                Visibility="Collapsed" Focusable="True"
                KeyDown="ImageOverlay_KeyDown">
            <Border.Background>
                <SolidColorBrush Color="#0F172A" Opacity="0.88"/>
            </Border.Background>
            <Grid>
                <!-- Clickable background to close (behind everything) -->
                <Border Background="Transparent" MouseLeftButtonDown="ImageOverlay_BgClick"/>

                <!-- Image (centered, with margins for arrows) -->
                <Image x:Name="OverlayImage" Stretch="Uniform" Margin="80,60"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       IsHitTestVisible="False"/>

                <!-- Close button (top-right, above image) -->
                <Button Style="{StaticResource IconButton}" HorizontalAlignment="Right"
                        VerticalAlignment="Top" Margin="20" Padding="14"
                        Click="ImageOverlay_CloseBtn">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                               Foreground="White"/>
                </Button>

                <!-- Prev arrow (left edge, tall hit area) -->
                <Button x:Name="OverlayPrevBtn" Style="{StaticResource IconButton}"
                        HorizontalAlignment="Left" VerticalAlignment="Stretch"
                        Width="72" Click="OverlayPrev_Click">
                    <Border Background="#44000000" CornerRadius="0,8,8,0" Padding="16,8"
                            VerticalAlignment="Center">
                        <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                   Foreground="White" VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </Button>

                <!-- Next arrow (right edge, tall hit area) -->
                <Button x:Name="OverlayNextBtn" Style="{StaticResource IconButton}"
                        HorizontalAlignment="Right" VerticalAlignment="Stretch"
                        Width="72" Click="OverlayNext_Click">
                    <Border Background="#44000000" CornerRadius="8,0,0,8" Padding="16,8"
                            VerticalAlignment="Center">
                        <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                   Foreground="White" VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </Button>

                <!-- File name + counter -->
                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                    <TextBlock x:Name="OverlayFileName" FontSize="14" Foreground="White"
                               FontWeight="Medium" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="OverlayCounter" FontSize="12" Foreground="#94A3B8"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- TOAST NOTIFICATION (light pill) -->
        <Border x:Name="ToastPanel" Grid.ColumnSpan="2" Panel.ZIndex="90"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,16,0,0" Visibility="Collapsed" IsHitTestVisible="True"
                RenderTransformOrigin="0.5,0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate"/>
            </Border.RenderTransform>
            <Border x:Name="ToastInner" Background="White" CornerRadius="10"
                    Padding="0" MinWidth="300" MaxWidth="540"
                    BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#1E293B" BlurRadius="20" ShadowDepth="6" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Color accent bar (left) -->
                    <Border x:Name="ToastAccent" Grid.Column="0" Background="{StaticResource InfoBrush}"
                            CornerRadius="10,0,0,10"/>
                    <!-- Content -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="14,10,8,10">
                        <TextBlock x:Name="ToastIcon" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   Foreground="{StaticResource InfoBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="ToastText" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="400"/>
                    </StackPanel>
                    <!-- Close button -->
                    <Border Grid.Column="2" Cursor="Hand" Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            MouseLeftButtonDown="ToastClose_Click">
                        <TextBlock x:Name="ToastCloseBtn" Text="&#xE711;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{StaticResource TextLightBrush}"
                                   VerticalAlignment="Center" Padding="6"/>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!-- DRAG & DROP OVERLAY -->
        <Border x:Name="DragDropOverlay" Grid.ColumnSpan="2" Panel.ZIndex="100"
                Visibility="Collapsed" IsHitTestVisible="False" Opacity="0">
            <Border.Background>
                <SolidColorBrush Color="#1D4ED8" Opacity="0.1"/>
            </Border.Background>
            <Grid x:Name="DragDropContent" HorizontalAlignment="Center" VerticalAlignment="Center"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="DragDropScale" ScaleX="0.9" ScaleY="0.9"/>
                </Grid.RenderTransform>
                <Rectangle Width="600" Height="300" Stroke="#1D4ED8" StrokeThickness="4"
                           StrokeDashArray="8 4" RadiusX="16" RadiusY="16" Fill="White" Opacity="0.95"/>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="80" Height="80" CornerRadius="40"
                            Background="{StaticResource PrimaryBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Suelta los archivos aqui" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Los archivos se subiran a esta carpeta" FontSize="14"
                               Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
