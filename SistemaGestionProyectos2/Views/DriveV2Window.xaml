<Window x:Class="SistemaGestionProyectos2.Views.DriveV2Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IMA Drive"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowDrop="True"
        Drop="Window_Drop"
        DragEnter="Window_DragEnter"
        DragLeave="Window_DragLeave"
        DragOver="Window_DragOver">

    <Window.Resources>
        <!-- ============================================= -->
        <!-- BRUSHES (Figma Slate palette)                 -->
        <!-- ============================================= -->
        <SolidColorBrush x:Key="PrimaryBrush"       Color="#1D4ED8"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush"   Color="#1E40AF"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush"    Color="#1E3A8A"/>
        <SolidColorBrush x:Key="PrimaryLightBrush"   Color="#3B82F6"/>
        <SolidColorBrush x:Key="BackgroundBrush"     Color="#F8FAFC"/>
        <SolidColorBrush x:Key="CardBgBrush"         Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ThemeBorderBrush"    Color="#E2E8F0"/>
        <SolidColorBrush x:Key="BorderLightBrush"    Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"    Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush"  Color="#475569"/>
        <SolidColorBrush x:Key="TextMutedBrush"      Color="#64748B"/>
        <SolidColorBrush x:Key="TextLightBrush"      Color="#94A3B8"/>
        <SolidColorBrush x:Key="SlateLight"          Color="#CBD5E1"/>
        <SolidColorBrush x:Key="HoverBgBrush"        Color="#F8FAFC"/>
        <SolidColorBrush x:Key="ActiveBgBrush"       Color="#EFF6FF"/>
        <SolidColorBrush x:Key="DestructiveBrush"    Color="#DC2626"/>
        <SolidColorBrush x:Key="DestructiveBgBrush"  Color="#FEF2F2"/>
        <SolidColorBrush x:Key="DestructiveHoverBrush" Color="#FEE2E2"/>

        <!-- ============================================= -->
        <!-- BUTTON STYLES                                 -->
        <!-- ============================================= -->

        <!-- Primary action button (blue bg, white text) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E3A8A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary action button (light bg, gray text, border) -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#E2E8F0" BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Destructive button (light red bg, red text) -->
        <Style x:Key="DestructiveButton" TargetType="Button">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FEE2E2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon button (transparent, shows bg on hover) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Link button (text only, turns blue on hover) -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1D4ED8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="content" Property="TextBlock.Foreground" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- View toggle button -->
        <Style x:Key="ViewToggleButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="256"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================= -->
        <!-- SIDEBAR                                       -->
        <!-- ============================================= -->
        <Border Grid.Column="0" Background="White"
                BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Storage indicator (bottom) -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="0,1,0,0"
                        Padding="16">
                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Almacenamiento" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="StorageLabel" Text="0 B de 10 GB" FontSize="12" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <!-- Progress bar -->
                            <Border Height="8" CornerRadius="4"
                                    Background="{StaticResource ThemeBorderBrush}" ClipToBounds="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="StorageFillCol" Width="5*"/>
                                        <ColumnDefinition x:Name="StorageEmptyCol" Width="95*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" CornerRadius="4">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                <GradientStop Color="#1D4ED8" Offset="0"/>
                                                <GradientStop Color="#3B82F6" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="StorageAvailLabel" Text="10 GB disponibles"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Navigation (fills remaining space) -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16">
                        <!-- Navigation items -->
                        <StackPanel x:Name="NavPanel"/>

                        <!-- File type filters -->
                        <TextBlock Text="FILTRAR POR TIPO" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="12,32,0,12"
                                   />
                        <StackPanel x:Name="FilterPanel"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ============================================= -->
        <!-- MAIN CONTENT                                  -->
        <!-- ============================================= -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid Margin="24,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo + Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1D4ED8" Offset="0"/>
                                    <GradientStop Color="#3B82F6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="IMA" Foreground="White" FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="IMA Drive" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Gestion de archivos" FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Search Bar -->
                    <Border Grid.Column="1" Margin="32,0"
                            Background="{StaticResource BackgroundBrush}"
                            BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="1"
                            CornerRadius="8" MaxWidth="640">
                        <Grid>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{StaticResource TextLightBrush}"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       IsHitTestVisible="False"/>
                            <TextBlock x:Name="SearchPlaceholder"
                                       Text="Buscar archivos, carpetas y ordenes de compra..."
                                       FontSize="14" Foreground="{StaticResource TextLightBrush}"
                                       VerticalAlignment="Center" Margin="36,0,12,0"
                                       IsHitTestVisible="False"/>
                            <TextBox x:Name="SearchBox" BorderThickness="0"
                                     Background="Transparent" FontSize="14"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     VerticalAlignment="Center" Padding="36,10,12,10"
                                     TextChanged="SearchBox_TextChanged"/>
                        </Grid>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- View toggle -->
                        <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8"
                                Padding="4" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="GridViewBtn" Style="{StaticResource ViewToggleButton}"
                                        Click="GridView_Click">
                                    <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                </Button>
                                <Button x:Name="ListViewBtn" Style="{StaticResource ViewToggleButton}"
                                        Click="ListView_Click">
                                    <TextBlock Text="&#xEA37;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Nueva carpeta -->
                        <Button Style="{StaticResource SecondaryButton}" Click="NewFolder_Click"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Nueva carpeta" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Subir archivo -->
                        <Button Style="{StaticResource PrimaryButton}" Click="Upload_Click"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Subir archivo" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Close window -->
                        <Button Style="{StaticResource IconButton}" Click="CloseWindow_Click"
                                ToolTip="Cerrar" Padding="8">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- BREADCRUMB -->
            <Border Grid.Row="1" Background="White"
                    BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="0,0,0,1"
                    Padding="24,12">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="BreadcrumbPanel" Orientation="Horizontal"/>
                </ScrollViewer>
            </Border>

            <!-- CONTENT AREA -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24">
                    <!-- Back to folders button -->
                    <Button x:Name="BackToFoldersBtn" Style="{StaticResource LinkButton}"
                            Click="BackToFolders_Click" Visibility="Collapsed"
                            HorizontalAlignment="Left" Margin="0,0,0,8">
                        <TextBlock>
                            <Run Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                            <Run Text=" Volver a carpetas"/>
                        </TextBlock>
                    </Button>

                    <!-- Section title -->
                    <TextBlock x:Name="SectionTitle" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="SectionSubtitle" FontSize="14"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,24"/>

                    <!-- Dynamic content host -->
                    <ContentControl x:Name="ContentHost"/>

                    <!-- Empty state -->
                    <StackPanel x:Name="EmptyState" HorizontalAlignment="Center"
                                VerticalAlignment="Center" Margin="0,80,0,0"
                                Visibility="Collapsed">
                        <Border Width="80" Height="80" CornerRadius="40"
                                Background="{StaticResource ActiveBgBrush}"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="32" Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Carpeta vacia" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Crea una carpeta o sube un archivo para comenzar"
                                   FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ============================================= -->
        <!-- DETAIL PANEL                                  -->
        <!-- ============================================= -->
        <Border x:Name="DetailPanel" Grid.Column="2" Width="320"
                Background="White"
                BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="1,0,0,0"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="20,16"
                        BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="Detalles del archivo" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Style="{StaticResource IconButton}"
                                HorizontalAlignment="Right" Click="DetailClose_Click">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Preview -->
                <Border Grid.Row="1" Padding="20,16"
                        BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <Border x:Name="DetailPreviewBg" CornerRadius="8" Height="120"
                                Margin="0,0,0,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#EFF6FF" Offset="0"/>
                                    <GradientStop Color="#DBEAFE" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock x:Name="DetailPreviewIcon" FontSize="40"
                                       Foreground="{StaticResource PrimaryBrush}" Opacity="0.6"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="DetailFileName" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
                        <TextBlock x:Name="DetailFileExt" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Info -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="INFORMACION" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,16"/>
                        <StackPanel x:Name="DetailInfoPanel"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Actions -->
                <Border Grid.Row="3" Padding="20,16"
                        BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <Button Style="{StaticResource PrimaryButton}" Click="DetailDownload_Click"
                                Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Descargar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Click="DetailLink_Click"
                                Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="Copiar enlace" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DestructiveButton}" Click="DetailDelete_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Eliminar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ============================================= -->
        <!-- DRAG & DROP OVERLAY                           -->
        <!-- ============================================= -->
        <Border x:Name="DragDropOverlay" Grid.ColumnSpan="3"
                Panel.ZIndex="100" Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border.Background>
                <SolidColorBrush Color="#1D4ED8" Opacity="0.1"/>
            </Border.Background>
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Rectangle Width="600" Height="300"
                           Stroke="#1D4ED8" StrokeThickness="4"
                           StrokeDashArray="8 4"
                           RadiusX="16" RadiusY="16"
                           Fill="White" Opacity="0.95"/>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="80" Height="80" CornerRadius="40"
                            Background="{StaticResource PrimaryBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="32" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Suelta los archivos aqui" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Los archivos se subiran a esta carpeta" FontSize="14"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
