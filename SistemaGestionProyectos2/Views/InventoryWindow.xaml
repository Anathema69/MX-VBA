<Window x:Class="SistemaGestionProyectos2.Views.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IMA - Inventario"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- ============================================= -->
        <!-- BRUSHES                                       -->
        <!-- ============================================= -->
        <SolidColorBrush x:Key="PrimaryBrush"       Color="#1D4ED8"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush"   Color="#1E40AF"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush"    Color="#1E3A8A"/>
        <SolidColorBrush x:Key="PrimaryLightBrush"   Color="#3B82F6"/>
        <SolidColorBrush x:Key="BackgroundBrush"     Color="#F8FAFC"/>
        <SolidColorBrush x:Key="CardBgBrush"         Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ThemeBorderBrush"    Color="#E2E8F0"/>
        <SolidColorBrush x:Key="BorderLightBrush"    Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"    Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush"  Color="#475569"/>
        <SolidColorBrush x:Key="TextMutedBrush"      Color="#64748B"/>
        <SolidColorBrush x:Key="TextLightBrush"      Color="#94A3B8"/>
        <SolidColorBrush x:Key="SuccessBrush"        Color="#48BB78"/>
        <SolidColorBrush x:Key="SuccessBgBrush"      Color="#F0FFF4"/>
        <SolidColorBrush x:Key="WarningBrush"        Color="#D97706"/>
        <SolidColorBrush x:Key="WarningBgBrush"      Color="#FFFBEB"/>
        <SolidColorBrush x:Key="DangerBrush"         Color="#EF4444"/>
        <SolidColorBrush x:Key="PrimaryBgBrush"      Color="#EFF6FF"/>

        <DropShadowEffect x:Key="CardShadow" Color="#1E293B" BlurRadius="16"
                           ShadowDepth="4" Opacity="0.08" Direction="270"/>
        <DropShadowEffect x:Key="CardHoverShadow" Color="#1E293B" BlurRadius="24"
                           ShadowDepth="8" Opacity="0.14" Direction="270"/>

        <!-- ============================================= -->
        <!-- BUTTON STYLES                                 -->
        <!-- ============================================= -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#1E40AF"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="border" Property="Background" Value="#1E3A8A"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="border" Property="Opacity" Value="0.5"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#F1F5F9"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="border" Property="Background" Value="#E2E8F0"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#F1F5F9"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- KPI Cards -->
            <RowDefinition Height="Auto"/>  <!-- Search + Action Bar -->
            <RowDefinition Height="*"/>     <!-- Cards Grid -->
            <RowDefinition Height="Auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- Logo Icon -->
                    <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,16,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1D4ED8" Offset="0"/>
                                <GradientStop Color="#1E3A8A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="&#xE773;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="INVENTARIO" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Gestion de componentes" FontSize="14"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Click="BackButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Volver" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ===== KPI CARDS (SupplierPendingView style) ===== -->
        <Grid Grid.Row="1" Margin="30,16,30,0" MaxWidth="900" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Productos -->
            <Border Grid.Column="0" Margin="0,0,8,0" Padding="14,10" Background="White" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="1" Opacity="0.06" BlurRadius="3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0">
                        <Border.Background>
                            <SolidColorBrush Color="#1D4ED8" Opacity="0.1"/>
                        </Border.Background>
                        <TextBlock Text="&#xE773;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   Foreground="#1D4ED8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Productos" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="TotalProductsText" Text="120" FontSize="20" FontWeight="Bold"
                                   Foreground="#1D4ED8" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Por Pedir -->
            <Border Grid.Column="1" Margin="4,0" Padding="14,10" Background="White" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="1" Opacity="0.06" BlurRadius="3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0">
                        <Border.Background>
                            <SolidColorBrush Color="#F59E0B" Opacity="0.1"/>
                        </Border.Background>
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   Foreground="#D97706" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Por pedir" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="LowStockTotalText" Text="13" FontSize="20" FontWeight="Bold"
                                   Foreground="#D97706" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Categorias -->
            <Border Grid.Column="2" Margin="8,0,0,0" Padding="14,10" Background="White" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="1" Opacity="0.06" BlurRadius="3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0">
                        <Border.Background>
                            <SolidColorBrush Color="#48BB78" Opacity="0.1"/>
                        </Border.Background>
                        <TextBlock Text="&#xF168;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   Foreground="#48BB78" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Categorias" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="TotalCategoriesText" Text="6" FontSize="20" FontWeight="Bold"
                                   Foreground="#48BB78" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== SEARCH + ACTION BAR ===== -->
        <Border Grid.Row="2" Margin="30,12,30,0" Padding="16" Background="White" CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Border Grid.Column="0" MaxWidth="400" HorizontalAlignment="Left"
                        Background="#F8FAFC" BorderBrush="{StaticResource ThemeBorderBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource TextLightBrush}"
                                   Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        <TextBox x:Name="SearchBox" BorderThickness="0" Background="Transparent"
                                 Padding="36,9,12,9" FontSize="13" VerticalAlignment="Center"
                                 TextChanged="SearchBox_TextChanged"/>
                        <TextBlock Text="Buscar categoria..." Margin="36,0,0,0"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextLightBrush}"
                                   FontSize="13" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text.Length, ElementName=SearchBox}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- New Category Button -->
                <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Click="NewCategory_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Nueva Categoria" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ===== CARDS GRID (centered, max-width constrained) ===== -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Background="{StaticResource BackgroundBrush}">
            <ItemsControl x:Name="CategoriesPanel" Margin="30,16,30,24"
                          MaxWidth="1100" HorizontalAlignment="Center"
                          VerticalAlignment="Top"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="12" Margin="6" Cursor="Hand"
                                MouseLeftButtonDown="CategoryCard_Click" Tag="{Binding}"
                                BorderBrush="#E2E8F0" BorderThickness="1"
                                Width="340">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#1E293B" BlurRadius="8" ShadowDepth="2" Opacity="0.06" Direction="270"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#94A3B8"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#1E293B" BlurRadius="20" ShadowDepth="6" Opacity="0.14" Direction="270"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <!-- Color bar left -->
                                <Border CornerRadius="12,0,0,12" Width="5" HorizontalAlignment="Left"
                                        Background="{Binding ColorBrush}"/>

                                <StackPanel Margin="20,18,20,16">
                                    <!-- Category Name -->
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>

                                    <!-- Description -->
                                    <TextBlock Text="{Binding Description}" FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               TextTrimming="CharacterEllipsis" MaxHeight="18"
                                               Margin="0,0,0,12"/>

                                    <!-- Separator -->
                                    <Border Height="1" Background="{StaticResource BorderLightBrush}" Margin="0,0,0,12"/>

                                    <!-- Stats -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="PRODUCTOS" FontSize="10" Foreground="{StaticResource TextLightBrush}"
                                                       FontWeight="SemiBold" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding ProductsCount}" FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="STOCK TOTAL" FontSize="10" Foreground="{StaticResource TextLightBrush}"
                                                       FontWeight="SemiBold" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding StockTotal}" FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Badge -->
                                    <Border CornerRadius="8" Padding="10,4" HorizontalAlignment="Left"
                                            Background="{Binding BadgeBg}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding BadgeIcon}" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{Binding BadgeFg}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding BadgeText}" FontSize="11"
                                                       Foreground="{Binding BadgeFg}" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ===== FOOTER ===== -->
        <Border Grid.Row="4" Background="White" BorderBrush="{StaticResource ThemeBorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="24,0" Height="36">
                <TextBlock x:Name="FooterCategoryCount" Text="6 categorias activas"
                           FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <TextBlock x:Name="FooterTimestamp" Text="Ultima actualizacion: 13/03/2026 14:30"
                           FontSize="12" Foreground="{StaticResource TextLightBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- ===== TOAST NOTIFICATIONS OVERLAY ===== -->
        <StackPanel x:Name="ToastContainer" Grid.Row="0" Grid.RowSpan="5"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    Margin="0,70,24,0" IsHitTestVisible="False"/>
    </Grid>
</Window>
