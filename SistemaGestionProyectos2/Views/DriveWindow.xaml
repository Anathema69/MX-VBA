<Window x:Class="SistemaGestionProyectos2.Views.DriveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IMA Mecatronica - Archivos"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Card base style -->
        <Style x:Key="DriveCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="Height" Value="130"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Breadcrumb button style -->
        <Style x:Key="BreadcrumbButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#1976D2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#0D47A1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Action button style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0D47A1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="Black">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <Border Width="100" Height="35" Margin="0,0,20,0">
                        <Grid>
                            <Rectangle Stroke="White" StrokeThickness="1.5"/>
                            <TextBlock Text="IMA" FontSize="18" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="ARCHIVOS" Foreground="White" FontSize="22"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button Content="+ Carpeta" Style="{StaticResource ActionButton}"
                            Click="NewFolder_Click" Margin="0,0,10,0"/>
                    <Button x:Name="UploadButton" Content="Subir archivo" Style="{StaticResource ActionButton}"
                            Click="Upload_Click" Margin="0,0,10,0"/>
                    <Button Content="Purgar R2" Click="PurgeR2_Click"
                            Background="#E53935" Foreground="White" BorderThickness="0"
                            Padding="12,8" FontSize="12" Cursor="Hand" Margin="0,0,10,0"
                            ToolTip="TEMPORAL: Elimina TODOS los archivos del bucket R2"/>
                    <Button Click="BackButton_Click" Background="Transparent"
                            BorderBrush="White" BorderThickness="1"
                            Foreground="White" Padding="15,5" Cursor="Hand"
                            Content="&#x2190; Volver"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BREADCRUMB -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="20,10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="BreadcrumbPanel" Orientation="Horizontal"/>
            </ScrollViewer>
        </Border>

        <!-- SELECTION BANNER (visible only in link-to-order mode) -->
        <Border x:Name="SelectionBanner" Grid.Row="2" Background="#FFF3E0"
                BorderBrush="#FF9800" BorderThickness="0,0,0,2"
                Padding="20,10" Visibility="Collapsed">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SelectionBannerText" FontSize="14"
                               Foreground="#E65100" VerticalAlignment="Center"
                               Text="Seleccione una carpeta para vincular"/>
                    <Button x:Name="LinkThisFolderButton" Content="Vincular esta carpeta"
                            Margin="20,0,0,0" Click="LinkThisFolder_Click"
                            Background="#FF9800" Foreground="White"
                            BorderThickness="0" Padding="12,6" Cursor="Hand"
                            FontWeight="Bold"/>
                    <Button Content="Cancelar" Margin="10,0,0,0" Click="CancelSelection_Click"
                            Background="Transparent" Foreground="#E65100"
                            BorderBrush="#E65100" BorderThickness="1"
                            Padding="12,6" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT AREA -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="12,8">
            <Grid>
                <!-- Items grid -->
                <WrapPanel x:Name="ContentPanel" Margin="8"
                           HorizontalAlignment="Left"/>

                <!-- Loading indicator -->
                <TextBlock x:Name="LoadingText" Text="Cargando..."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="16" Foreground="#999" Visibility="Collapsed"/>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyState" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="&#x1F4C2;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Carpeta vacia" FontSize="16" Foreground="#999"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Crea una carpeta o sube un archivo para comenzar"
                               FontSize="13" Foreground="#BBB" HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- UPLOAD PROGRESS PANEL -->
        <Border x:Name="UploadPanel" Grid.Row="3" Background="#E3F2FD"
                BorderBrush="#90CAF9" BorderThickness="0,1,0,0"
                Padding="12,6" Visibility="Collapsed"
                VerticalAlignment="Bottom" MaxHeight="120">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="UploadItemsPanel"/>
            </ScrollViewer>
        </Border>

        <!-- STATUS BAR -->
        <Border Grid.Row="4" Background="#333">
            <Grid Margin="20,0">
                <TextBlock x:Name="StatusText" Text="Listo"
                           Foreground="White" VerticalAlignment="Center" FontSize="12"/>
                <TextBlock x:Name="LinkedOrderText" Text=""
                           Foreground="#90CAF9" VerticalAlignment="Center"
                           HorizontalAlignment="Right" FontSize="12"/>
            </Grid>
        </Border>

        <!-- CONTEXT MENU for folders -->
        <Grid.ContextMenu>
            <ContextMenu x:Name="FolderContextMenu">
                <MenuItem Header="Abrir" Click="ContextOpen_Click"/>
                <MenuItem Header="Renombrar" Click="ContextRename_Click"/>
                <Separator/>
                <MenuItem Header="Vincular a Orden..." Click="ContextLinkOrder_Click"/>
                <MenuItem x:Name="ContextUnlinkItem" Header="Desvincular de Orden" Click="ContextUnlinkOrder_Click"/>
                <Separator/>
                <MenuItem Header="Eliminar" Click="ContextDelete_Click" Foreground="#E53935"/>
            </ContextMenu>
        </Grid.ContextMenu>
    </Grid>
</Window>
