<Window x:Class="SistemaGestionProyectos2.Views.StressTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Test de Estres - Rendimiento"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FAFAFA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E5E5E5" BorderThickness="0,0,0,1">
            <Grid Margin="32,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo y Titulo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#F4F4F5" CornerRadius="8" Padding="10">
                        <TextBlock Text="IMA" FontSize="14" FontWeight="Bold" Foreground="#18181B"/>
                    </Border>
                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Test de Estres - Rendimiento"
                                   FontSize="20" FontWeight="SemiBold" Foreground="#18181B"/>
                        <TextBlock Text="23 tests de rendimiento en 4 categorias (read-only)"
                                   FontSize="12" Foreground="#71717A" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Botones de accion -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Name="btnRun" Content="Ejecutar Tests"
                            Padding="24,10" FontSize="14" FontWeight="SemiBold"
                            Foreground="White" Cursor="Hand"
                            Click="BtnRun_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Name="border" Background="#18181B"
                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#3F3F46"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Background" Value="#A1A1AA"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Name="btnRunWorkflow" Content="Ejecutar Workflow"
                            Margin="12,0,0,0" Padding="24,10" FontSize="14" FontWeight="SemiBold"
                            Foreground="White" Cursor="Hand"
                            Click="BtnRunWorkflow_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Name="border" Background="#0D9488"
                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#0F766E"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Background" Value="#99F6E4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Name="btnCopy" Content="Copiar Reporte JSON"
                            Margin="12,0,0,0" Padding="16,10" FontSize="13"
                            Foreground="#71717A" Cursor="Hand" IsEnabled="False"
                            Click="BtnCopy_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Name="border" Background="Transparent"
                                        BorderBrush="#E5E5E5" BorderThickness="1"
                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#F4F4F5"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Boton Cerrar -->
                <Button Name="btnClose" Grid.Column="2"
                        Content="← Volver" FontSize="13"
                        Padding="16,8" Foreground="#71717A" Cursor="Hand"
                        Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Name="border" Background="Transparent"
                                    BorderBrush="#E5E5E5" BorderThickness="1"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#F4F4F5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Contenido Principal -->
        <Grid Grid.Row="1" Margin="32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Progress Bar -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <Grid Margin="0,0,0,6">
                    <TextBlock Name="txtProgress" Text="Listo para ejecutar"
                               FontSize="13" Foreground="#71717A"/>
                    <TextBlock Name="txtProgressCount" Text=""
                               FontSize="13" Foreground="#71717A" HorizontalAlignment="Right"/>
                </Grid>
                <ProgressBar Name="pbProgress" Height="6" Minimum="0" Maximum="23" Value="0"
                             Background="#E5E5E5" Foreground="#18181B" BorderThickness="0">
                    <ProgressBar.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </ProgressBar.Resources>
                </ProgressBar>
            </StackPanel>

            <!-- Lista de Resultados -->
            <Border Grid.Row="1" Background="White" CornerRadius="8"
                    BorderBrush="#E5E5E5" BorderThickness="1">
                <ListView Name="lvResults" BorderThickness="0" Background="Transparent"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="#" Width="45">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Index}" FontSize="12"
                                                   Foreground="#71717A" TextAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Categoria" Width="130">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding CategoryBg}" CornerRadius="4" Padding="8,2">
                                            <TextBlock Text="{Binding Category}" FontSize="12"
                                                       Foreground="{Binding CategoryFg}" FontWeight="Medium"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Test" Width="300">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                   Foreground="#18181B"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Tiempo (ms)" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ElapsedMs}" FontSize="13"
                                                   Foreground="#18181B" FontWeight="SemiBold"
                                                   TextAlignment="Right"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Threshold (ms)" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ThresholdMs}" FontSize="12"
                                                   Foreground="#71717A" TextAlignment="Right"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Estado" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusBg}" CornerRadius="4" Padding="10,3">
                                            <TextBlock Text="{Binding Status}" FontSize="12"
                                                       Foreground="{Binding StatusFg}" FontWeight="SemiBold"
                                                       TextAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <!-- Panel Resumen -->
            <Border Grid.Row="2" Background="White" CornerRadius="8" Margin="0,16,0,0"
                    BorderBrush="#E5E5E5" BorderThickness="1">
                <Grid Margin="24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Total Tests" FontSize="12" Foreground="#71717A"/>
                        <TextBlock Name="txtTotal" Text="0 / 23"
                                   FontSize="24" FontWeight="SemiBold" Foreground="#18181B" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Pasaron" FontSize="12" Foreground="#71717A"/>
                        <TextBlock Name="txtPassed" Text="0"
                                   FontSize="24" FontWeight="SemiBold" Foreground="#22C55E" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fallaron" FontSize="12" Foreground="#71717A"/>
                        <TextBlock Name="txtFailed" Text="0"
                                   FontSize="24" FontWeight="SemiBold" Foreground="#EF4444" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Tiempo Total" FontSize="12" Foreground="#71717A"/>
                        <TextBlock Name="txtTotalTime" Text="--"
                                   FontSize="24" FontWeight="SemiBold" Foreground="#18181B" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
