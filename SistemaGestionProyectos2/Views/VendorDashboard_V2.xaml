<Window x:Class="SistemaGestionProyectos2.Views.VendorDashboard_V2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mis Comisiones"
        Height="900" Width="1500"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal" WindowStyle="None" ResizeMode="NoResize">

    <Window.Resources>
        <!-- ============================================= -->
        <!-- COLORES                                       -->
        <!-- ============================================= -->
        <SolidColorBrush x:Key="Primary" Color="#5B3FF9"/>
        <SolidColorBrush x:Key="PrimaryLight" Color="#EDE9FE"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#4C1D95"/>
        <SolidColorBrush x:Key="Amber" Color="#F59E0B"/>
        <SolidColorBrush x:Key="AmberDark" Color="#D97706"/>
        <SolidColorBrush x:Key="AmberBg" Color="#FFFBEB"/>
        <SolidColorBrush x:Key="AmberText" Color="#78350F"/>
        <SolidColorBrush x:Key="Success" Color="#10B981"/>
        <SolidColorBrush x:Key="SuccessBg" Color="#D1FAE5"/>
        <SolidColorBrush x:Key="SuccessText" Color="#065F46"/>
        <SolidColorBrush x:Key="Danger" Color="#EF4444"/>
        <SolidColorBrush x:Key="DangerBg" Color="#FEE2E2"/>
        <SolidColorBrush x:Key="DangerText" Color="#991B1B"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="BorderLight" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="BgGray" Color="#F7FAFC"/>
        <SolidColorBrush x:Key="TextDark" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextBody" Color="#475569"/>
        <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>
        <SolidColorBrush x:Key="TextLight" Color="#94A3B8"/>

        <!-- Compat aliases -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#5B3FF9"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#10B981"/>
        <SolidColorBrush x:Key="DangerColor" Color="#EF4444"/>
        <SolidColorBrush x:Key="WarningColor" Color="#F59E0B"/>
        <SolidColorBrush x:Key="InfoColor" Color="#3B82F6"/>
        <SolidColorBrush x:Key="BackgroundGray" Color="#F7FAFC"/>
        <SolidColorBrush x:Key="BorderGray" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextGray" Color="#64748B"/>
        <SolidColorBrush x:Key="DarkText" Color="#1E293B"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <DropShadowEffect x:Key="CardShadow" Color="#1E293B" BlurRadius="10"
                          ShadowDepth="1" Opacity="0.05" Direction="270"/>
        <DropShadowEffect x:Key="AmberGlow" Color="#F59E0B" BlurRadius="12"
                          ShadowDepth="3" Opacity="0.25" Direction="270"/>

        <!-- ============================================= -->
        <!-- BOTON LIBERAR ORDEN (AMARILLO)                -->
        <!-- ============================================= -->
        <Style x:Key="BtnRelease" TargetType="Button">
            <Setter Property="Foreground" Value="#78350F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8" Padding="20,10"
                                Effect="{StaticResource AmberGlow}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#F59E0B" Offset="0"/>
                                    <GradientStop Color="#FBBF24" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#D97706" Offset="0"/>
                                            <GradientStop Color="#F59E0B" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#E2E8F0"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="bd" Property="Effect" Value="{x:Null}"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================= -->
        <!-- BOTON OUTLINE (subir archivos)                -->
        <!-- ============================================= -->
        <Style x:Key="BtnOutline" TargetType="Button">
            <Setter Property="Background" Value="#EDE9FE"/>
            <Setter Property="Foreground" Value="#5B3FF9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="#5B3FF9" BorderThickness="1.5"
                                CornerRadius="6" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DDD6FE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgGray}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER (compacto ~56px) ===== -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1">
            <Grid Margin="24,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="38" Height="38" CornerRadius="10" Margin="0,0,12,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#5B3FF9" Offset="0"/>
                                <GradientStop Color="#764BA2" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Name="VendorInitials" Text="--" FontSize="16" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Name="VendorNameText" Text="Mis Comisiones" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextDark}"/>
                        <TextBlock Text="Panel de Vendedor" FontSize="11"
                                   Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="RefreshButton" Click="RefreshButton_Click" ToolTip="Actualizar"
                            Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                            Cursor="Hand" Padding="8,6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Actualizar" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="LogoutButton_Click" Width="120" Height="32"
                            Background="White" BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6" Name="Bd">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#F7FAFC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"
                                       Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Text="Cerrar Sesion" FontSize="12" Foreground="{StaticResource TextBody}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== KPI CARDS (compacto ~70px) ===== -->
        <Grid Grid.Row="1" Margin="24,10,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,8,0" Padding="14,10" Background="White" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="1" Opacity="0.06" BlurRadius="3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="#EF4444" Opacity="0.1"/>
                        </Border.Background>
                        <TextBlock Text="&#xEA3A;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource Danger}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Por Completar" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Name="TotalDraftText" Text="$0.00" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Danger}"/>
                            <TextBlock Name="DraftCountText" Text="0 ordenes" FontSize="11" Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Bottom" Margin="8,0,0,2"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="4,0" Padding="14,10" Background="White" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="1" Opacity="0.06" BlurRadius="3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="#F59E0B" Opacity="0.1"/>
                        </Border.Background>
                        <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource Amber}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="En Proceso" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Name="TotalPendingText" Text="$0.00" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Amber}"/>
                            <TextBlock Name="PendingCountText" Text="0 ordenes" FontSize="11" Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Bottom" Margin="8,0,0,2"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Margin="8,0,0,0" Padding="14,10" Background="White" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="1" Opacity="0.06" BlurRadius="3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="#10B981" Opacity="0.1"/>
                        </Border.Background>
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource Success}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Pagado" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Name="TotalPaidText" Text="$0.00" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Success}"/>
                            <TextBlock Name="PaidCountText" Text="0 ordenes" FontSize="11" Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Bottom" Margin="8,0,0,2"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== COMMISSIONS LIST ===== -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Padding="24,12,24,12">
            <Grid>
                <ItemsControl Name="CommissionsItemsControl"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- ====== COMMISSION CARD ====== -->
                            <Border Margin="0,0,0,10" Background="White" CornerRadius="10" ClipToBounds="True">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="#6366F1"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="1" Opacity="0.04" BlurRadius="6"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Status bar lateral -->
                                    <Rectangle Grid.Column="0" RadiusX="2" RadiusY="2">
                                        <Rectangle.Style>
                                            <Style TargetType="Rectangle">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="draft">
                                                        <Setter Property="Fill" Value="{StaticResource Danger}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="pending">
                                                        <Setter Property="Fill" Value="{StaticResource Amber}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="paid">
                                                        <Setter Property="Fill" Value="{StaticResource Success}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                    </Rectangle>

                                    <StackPanel Grid.Column="1">
                                        <!-- ======== ROW 1: Orden + badge + monto (misma linea) ======== -->
                                        <Grid Margin="16,10,16,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextDark}">
                                                    <Run Text="Orden: "/><Run Text="{Binding OrderNumber}"/>
                                                </TextBlock>
                                                <Border Margin="8,0,0,0" CornerRadius="5" Padding="8,2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="draft">
                                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="pending">
                                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="paid">
                                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="11" FontWeight="Medium">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="draft">
                                                                        <Setter Property="Text" Value="Por completar"/>
                                                                        <Setter Property="Foreground" Value="#991B1B"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="pending">
                                                                        <Setter Property="Text" Value="En proceso"/>
                                                                        <Setter Property="Foreground" Value="#92400E"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="paid">
                                                                        <Setter Property="Text" Value="Pagado"/>
                                                                        <Setter Property="Foreground" Value="#065F46"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1" Text="{Binding CommissionAmountFormatted}" FontSize="22" FontWeight="Bold"
                                                       Foreground="{StaticResource TextDark}" VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- ======== ROW 2: Cliente · Fecha · Detalle (una linea) ======== -->
                                        <StackPanel Orientation="Horizontal" Margin="16,3,16,8">
                                            <TextBlock Text="{Binding ClientName}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextDark}"/>
                                            <TextBlock Text=" · " FontSize="12" Foreground="{StaticResource TextLight}"/>
                                            <TextBlock Text="{Binding OrderDate, StringFormat='{}{0:dd/MM/yyyy}'}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                                            <!-- Detalle (solo si existe) -->
                                            <StackPanel Orientation="Horizontal">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding OrderDescription}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding OrderDescription}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Text=" · " FontSize="12" Foreground="{StaticResource TextLight}"/>
                                                <TextBlock Text="{Binding OrderDescription}" FontSize="12" Foreground="{StaticResource TextMuted}"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- ======== FILES ZONE (inline chips) ======== -->
                                        <Border Background="{StaticResource BgGray}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="12,8">
                                            <ItemsControl ItemsSource="{Binding Files}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="6" Margin="0,0,6,4" Cursor="Hand"
                                                                Padding="8,5,10,5" Name="FileChip"
                                                                Background="White" BorderThickness="1" BorderBrush="#E5E7EB"
                                                                MouseLeftButtonDown="FileChip_Click"
                                                                MouseRightButtonUp="FileChip_RightClick"
                                                                Tag="{Binding}">
                                                            <Border.ToolTip>
                                                                <StackPanel MaxWidth="200">
                                                                    <TextBlock Text="{Binding FileName}" FontWeight="Medium" FontSize="12"/>
                                                                    <TextBlock Text="Clic para previsualizar · Clic derecho para opciones"
                                                                               FontSize="11" Foreground="#64748B" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                                                </StackPanel>
                                                            </Border.ToolTip>
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <!-- Extension badge -->
                                                                <Border CornerRadius="4" Padding="4,2" Margin="0,0,6,0" VerticalAlignment="Center">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#64748B"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding FileExt}" Value="JPG"><Setter Property="Background" Value="#3B82F6"/></DataTrigger>
                                                                                <DataTrigger Binding="{Binding FileExt}" Value="JPEG"><Setter Property="Background" Value="#3B82F6"/></DataTrigger>
                                                                                <DataTrigger Binding="{Binding FileExt}" Value="JFIF"><Setter Property="Background" Value="#3B82F6"/></DataTrigger>
                                                                                <DataTrigger Binding="{Binding FileExt}" Value="PNG"><Setter Property="Background" Value="#8B5CF6"/></DataTrigger>
                                                                                <DataTrigger Binding="{Binding FileExt}" Value="PDF"><Setter Property="Background" Value="#EF4444"/></DataTrigger>
                                                                                <DataTrigger Binding="{Binding FileExt}" Value="XLS"><Setter Property="Background" Value="#10B981"/></DataTrigger>
                                                                                <DataTrigger Binding="{Binding FileExt}" Value="XLSX"><Setter Property="Background" Value="#10B981"/></DataTrigger>
                                                                                <DataTrigger Binding="{Binding FileExt}" Value="DOC"><Setter Property="Background" Value="#3B82F6"/></DataTrigger>
                                                                                <DataTrigger Binding="{Binding FileExt}" Value="DOCX"><Setter Property="Background" Value="#3B82F6"/></DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="{Binding FileExt}" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                                </Border>
                                                                <!-- Name + size -->
                                                                <StackPanel VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding FileName}" FontSize="11" FontWeight="Medium"
                                                                               Foreground="{StaticResource TextBody}" TextTrimming="CharacterEllipsis"
                                                                               MaxWidth="120"/>
                                                                    <TextBlock Text="{Binding FileSizeFormatted}" FontSize="9"
                                                                               Foreground="{StaticResource TextLight}" Margin="0,-1,0,0"/>
                                                                </StackPanel>
                                                                <!-- More options hint (visible on hover) -->
                                                                <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets"
                                                                           FontSize="10" Foreground="{StaticResource TextMuted}"
                                                                           VerticalAlignment="Center" Margin="4,0,0,0"
                                                                           Name="MoreIcon" Visibility="Collapsed"
                                                                           ToolTip="Clic derecho para opciones"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <DataTemplate.Triggers>
                                                            <Trigger SourceName="FileChip" Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="FileChip" Property="BorderBrush" Value="#6366F1"/>
                                                                <Setter TargetName="FileChip" Property="Background" Value="#F5F3FF"/>
                                                                <Setter TargetName="MoreIcon" Property="Visibility" Value="Visible"/>
                                                            </Trigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                        <!-- Upload [+] button (not paid) -->
                                        <Border Background="{StaticResource BgGray}" Padding="12,0,12,8"
                                                BorderBrush="{StaticResource BorderColor}" BorderThickness="0">
                                            <Button Tag="{Binding}" Click="UploadFile_Click" Cursor="Hand"
                                                    HorizontalAlignment="Left" BorderThickness="0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border CornerRadius="6" Padding="8,4,10,4"
                                                                            Background="White" BorderThickness="1"
                                                                            BorderBrush="#D4D4D8" Name="AddBg"
                                                                            Cursor="Hand">
                                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                                                                       FontSize="11" Foreground="{StaticResource Primary}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                            <TextBlock Text="Subir Factura" FontSize="11" FontWeight="Medium"
                                                                                       Foreground="{StaticResource Primary}"
                                                                                       VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="AddBg" Property="Background" Value="#EDE9FE"/>
                                                                            <Setter TargetName="AddBg" Property="BorderBrush" Value="{StaticResource Primary}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="paid">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Border>

                                        <!-- ======== ACTION BAR: draft + hasFiles → "Liberar Orden" ======== -->
                                        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="16,10">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding Status}" Value="draft"/>
                                                                <Condition Binding="{Binding HasFiles}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Width="28" Height="28" CornerRadius="6" Background="#FFFBEB"
                                                            Margin="0,0,10,0">
                                                        <TextBlock Text="&#xEA80;" FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="12" Foreground="#F59E0B"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="Archivos listos — solicite la liberacion para procesar el pago"
                                                               FontSize="12" Foreground="{StaticResource TextBody}" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <Button Grid.Column="1" Tag="{Binding}" Click="SolicitarLiberacion_Click"
                                                        Style="{StaticResource BtnRelease}" Margin="16,0,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE785;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                   Foreground="#78350F" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Liberar Orden" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" &#x2192;" FontSize="14" Opacity="0.6" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <!-- ======== ACTION BAR: draft + !hasFiles → disabled ======== -->
                                        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="16,10">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding Status}" Value="draft"/>
                                                                <Condition Binding="{Binding HasFiles}" Value="False"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Suba las facturas firmadas para habilitar la liberacion"
                                                           FontSize="12" Foreground="{StaticResource TextLight}" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Style="{StaticResource BtnRelease}"
                                                        IsEnabled="False" Margin="16,0,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE785;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Liberar Orden" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" &#x2192;" FontSize="14" Opacity="0.6" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <!-- ======== PENDING: Stepper 3 pasos ======== -->
                                        <Border BorderThickness="0,1,0,0" Padding="16,10">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Setter Property="Background" Value="#FFFBEB"/>
                                                    <Setter Property="BorderBrush" Value="#FDE68A"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="pending"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Badge -->
                                                <Border Grid.Column="0" Background="White" CornerRadius="6"
                                                        Padding="10,4" BorderBrush="#FDE68A" BorderThickness="1"
                                                        VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                   Foreground="#D97706" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Procesando pago" FontSize="12"
                                                                   FontWeight="SemiBold" Foreground="#92400E"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Progress steps -->
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <!-- Step 1: Done -->
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="18" Height="18" CornerRadius="9" Background="#10B981">
                                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="Liberada" FontSize="10" Foreground="#065F46"
                                                                   FontWeight="Medium" VerticalAlignment="Center" Margin="4,0"/>
                                                    </StackPanel>
                                                    <Border Width="20" Height="2" Background="#D97706" VerticalAlignment="Center"
                                                            Margin="4,0" CornerRadius="1"/>
                                                    <!-- Step 2: Current -->
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="18" Height="18" CornerRadius="9" Background="#F59E0B">
                                                            <Border Width="8" Height="8" CornerRadius="4" Background="White"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="Revision" FontSize="10" Foreground="#92400E"
                                                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0"/>
                                                    </StackPanel>
                                                    <Border Width="20" Height="2" Background="#E2E8F0" VerticalAlignment="Center"
                                                            Margin="4,0" CornerRadius="1"/>
                                                    <!-- Step 3: Pending -->
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="18" Height="18" CornerRadius="9" Background="White"
                                                                BorderBrush="#E2E8F0" BorderThickness="2"/>
                                                        <TextBlock Text="Pago" FontSize="10" Foreground="{StaticResource TextLight}"
                                                                   VerticalAlignment="Center" Margin="4,0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- No data -->
                <StackPanel Name="NoDataPanel" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,0,0" Visibility="Collapsed">
                    <Border Width="56" Height="56" CornerRadius="28"
                            Background="{StaticResource PrimaryLight}"
                            HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="24" Foreground="{StaticResource Primary}" Opacity="0.5"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Name="NoDataTitle" Text="No hay comisiones" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Name="NoDataMessage" Text="No se encontraron comisiones" FontSize="12" Foreground="{StaticResource TextLight}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ===== STATUS BAR ===== -->
        <Border Grid.Row="3" Background="{StaticResource TextDark}" Height="26">
            <Grid Margin="16,0">
                <TextBlock Text="Listo" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Name="StatusBarTime" Text="" Foreground="White" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
