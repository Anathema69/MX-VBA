<Window x:Class="SistemaGestionProyectos2.Views.VendorPhotoMockup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VendorDashboard — Mockup Galería de Fotos"
        Height="860" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F7FAFC">

    <Window.Resources>
        <!-- ============================================= -->
        <!-- COLORES                                       -->
        <!-- ============================================= -->
        <SolidColorBrush x:Key="Primary" Color="#5B3FF9"/>
        <SolidColorBrush x:Key="PrimaryLight" Color="#EDE9FE"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#4C1D95"/>
        <SolidColorBrush x:Key="Amber" Color="#F59E0B"/>
        <SolidColorBrush x:Key="AmberDark" Color="#D97706"/>
        <SolidColorBrush x:Key="AmberBg" Color="#FFFBEB"/>
        <SolidColorBrush x:Key="AmberText" Color="#78350F"/>
        <SolidColorBrush x:Key="Success" Color="#10B981"/>
        <SolidColorBrush x:Key="SuccessBg" Color="#D1FAE5"/>
        <SolidColorBrush x:Key="SuccessText" Color="#065F46"/>
        <SolidColorBrush x:Key="Danger" Color="#EF4444"/>
        <SolidColorBrush x:Key="DangerBg" Color="#FEE2E2"/>
        <SolidColorBrush x:Key="DangerText" Color="#991B1B"/>
        <SolidColorBrush x:Key="Border" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="BorderLight" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="BgGray" Color="#F7FAFC"/>
        <SolidColorBrush x:Key="TextDark" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextBody" Color="#475569"/>
        <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>
        <SolidColorBrush x:Key="TextLight" Color="#94A3B8"/>

        <!-- Sombra reutilizable -->
        <DropShadowEffect x:Key="CardShadow" Color="#1E293B" BlurRadius="12"
                          ShadowDepth="2" Opacity="0.06" Direction="270"/>
        <DropShadowEffect x:Key="AmberGlow" Color="#F59E0B" BlurRadius="16"
                          ShadowDepth="4" Opacity="0.3" Direction="270"/>

        <!-- ============================================= -->
        <!-- BOTON PRIMARIO MORADO                         -->
        <!-- ============================================= -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#5B3FF9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4C1D95"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================= -->
        <!-- BOTON LIBERAR ORDEN (AMARILLO)                -->
        <!-- ============================================= -->
        <Style x:Key="BtnRelease" TargetType="Button">
            <Setter Property="Foreground" Value="#78350F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="10" Padding="28,14"
                                Effect="{StaticResource AmberGlow}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#F59E0B" Offset="0"/>
                                    <GradientStop Color="#FBBF24" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#D97706" Offset="0"/>
                                            <GradientStop Color="#F59E0B" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#E2E8F0"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="bd" Property="Effect" Value="{x:Null}"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================= -->
        <!-- BOTON OUTLINE (subir archivos)                -->
        <!-- ============================================= -->
        <Style x:Key="BtnOutline" TargetType="Button">
            <Setter Property="Background" Value="#EDE9FE"/>
            <Setter Property="Foreground" Value="#5B3FF9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="#5B3FF9" BorderThickness="1.5"
                                CornerRadius="8" Padding="14,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DDD6FE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================= -->
        <!-- BOTON ICONO (hover, descarga, eliminar)       -->
        <!-- ============================================= -->
        <Style x:Key="BtnIcon" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="40,30">

            <!-- ============================================= -->
            <!-- TITULO                                        -->
            <!-- ============================================= -->
            <TextBlock Text="Mockup — Sección de Fotos y Liberación" FontSize="22"
                       FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,0,0,6"/>
            <TextBlock Text="Referencia visual para VendorDashboard. 3 variantes de la card de comisión."
                       FontSize="14" Foreground="{StaticResource TextMuted}" Margin="0,0,0,30"/>

            <!-- ============================================= -->
            <!-- VARIANTE 1: DRAFT — CON ARCHIVOS + LIBERAR    -->
            <!-- ============================================= -->
            <TextBlock Text="VARIANTE 1: POR COMPLETAR (DRAFT) — CON ARCHIVOS" FontSize="11"
                       FontWeight="Bold" Foreground="{StaticResource TextLight}" Margin="0,0,0,10"
                      />

            <Border Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1"
                    Margin="0,0,0,30" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="1" Opacity="0.06" BlurRadius="8"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Barra lateral de estado -->
                    <Rectangle Grid.Column="0" Fill="{StaticResource Danger}" RadiusX="2" RadiusY="2"/>

                    <StackPanel Grid.Column="1">
                        <!-- === HEADER: Orden + Monto === -->
                        <Grid Margin="24,20,24,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Orden: 9000006318" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextDark}"/>
                                    <Border Background="#FEE2E2" CornerRadius="6" Padding="10,3" Margin="10,0,0,0">
                                        <TextBlock Text="Por completar" FontSize="12" FontWeight="Medium"
                                                   Foreground="#991B1B"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Cliente:" FontSize="14" Foreground="{StaticResource TextMuted}"
                                                   FontWeight="Medium" Width="65"/>
                                        <TextBlock Text="Lennox" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextDark}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Detalle:" FontSize="14" Foreground="{StaticResource TextMuted}"
                                                   FontWeight="Medium" Width="65"/>
                                        <TextBlock Text="Reparación de horquilla hidráulica" FontSize="14"
                                                   FontWeight="Medium" Foreground="{StaticResource TextDark}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Fecha:" FontSize="14" Foreground="{StaticResource TextMuted}"
                                                   FontWeight="Medium" Width="65"/>
                                        <TextBlock Text="15/02/2026" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextDark}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                                <TextBlock Text="$4,500.00" FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource TextDark}" HorizontalAlignment="Right"/>
                                <TextBlock Text="Comisión" FontSize="12" Foreground="{StaticResource TextMuted}"
                                           HorizontalAlignment="Right" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- === ZONA DE ARCHIVOS === -->
                        <Border Background="{StaticResource BgGray}" BorderBrush="{StaticResource Border}"
                                BorderThickness="0,1,0,0" Padding="24,16">
                            <StackPanel>
                                <!-- Header: Toggle + Upload -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="{StaticResource TextMuted}" Margin="0,0,10,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Facturas y comprobantes" FontSize="14"
                                                   FontWeight="Medium" Foreground="{StaticResource TextBody}"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="{StaticResource Border}" CornerRadius="10"
                                                Padding="8,3" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="6" FontSize="11" FontWeight="Bold"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </Border>
                                        <Border Background="White" CornerRadius="4" Width="24" Height="24"
                                                Margin="10,0,0,0" VerticalAlignment="Center"
                                                BorderBrush="{StaticResource Border}" BorderThickness="1">
                                            <TextBlock Text="▲" FontSize="9" FontWeight="Bold"
                                                       Foreground="{StaticResource TextMuted}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>

                                    <Button Grid.Column="1" Style="{StaticResource BtnOutline}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                                                       Foreground="#5B3FF9" Margin="0,-2,6,0"/>
                                            <TextBlock Text="Subir archivos" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#5B3FF9" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <!-- Galería de thumbnails -->
                                <WrapPanel Orientation="Horizontal">
                                    <!-- Thumb 1: Imagen -->
                                    <Border Width="148" Height="148" CornerRadius="10" Margin="0,0,10,10"
                                            ClipToBounds="True" BorderBrush="#E5E7EB" BorderThickness="1"
                                            Cursor="Hand">
                                        <Grid>
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#DBEAFE" Offset="0"/>
                                                        <GradientStop Color="#BFDBFE" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="42" Foreground="#3B82F6" Opacity="0.5"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Background="#3B82F6" CornerRadius="6" Padding="6,3"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Margin="0,8,8,0">
                                                <TextBlock Text="JPG" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                            <Border VerticalAlignment="Bottom" Padding="10,20,10,8">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#00181818" Offset="0"/>
                                                        <GradientStop Color="#D9181818" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel>
                                                    <TextBlock Text="factura_firmada.jpg" FontSize="11"
                                                               FontWeight="Medium" Foreground="White"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="2.4 MB" FontSize="10" Foreground="#99FFFFFF"
                                                               Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Thumb 2: Imagen con hover overlay visible (demo) -->
                                    <Border Width="148" Height="148" CornerRadius="10" Margin="0,0,10,10"
                                            ClipToBounds="True" BorderBrush="#6366F1" BorderThickness="2"
                                            Cursor="Hand">
                                        <Grid>
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#ECFDF5" Offset="0"/>
                                                        <GradientStop Color="#D1FAE5" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="42" Foreground="#10B981" Opacity="0.4"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <!-- HOVER OVERLAY (siempre visible para demo) -->
                                            <Border Background="#A618181B">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                                    <!-- Ver -->
                                                    <Border Width="38" Height="38" CornerRadius="8"
                                                            Background="#44FFFFFF" Margin="0,0,6,0" Cursor="Hand">
                                                        <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="15" Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <!-- Descargar -->
                                                    <Border Width="38" Height="38" CornerRadius="8"
                                                            Background="#B33B82F6" Margin="0,0,6,0" Cursor="Hand">
                                                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="15" Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <!-- Eliminar -->
                                                    <Border Width="38" Height="38" CornerRadius="8"
                                                            Background="#B3EF4444" Cursor="Hand">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="15" Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Thumb 3: PDF -->
                                    <Border Width="148" Height="148" CornerRadius="10" Margin="0,0,10,10"
                                            ClipToBounds="True" BorderBrush="#E5E7EB" BorderThickness="1"
                                            Cursor="Hand" Background="#FEF2F2">
                                        <Grid>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xEA90;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="38" Foreground="#EF4444" Opacity="0.7"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="PDF" FontSize="11" FontWeight="Bold"
                                                           Foreground="#EF4444" Opacity="0.6"
                                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                            </StackPanel>
                                            <Border Background="#EF4444" CornerRadius="6" Padding="6,3"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Margin="0,8,8,0">
                                                <TextBlock Text="PDF" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                            <Border VerticalAlignment="Bottom" Padding="10,16,10,8">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#00181818" Offset="0"/>
                                                        <GradientStop Color="#CC181818" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel>
                                                    <TextBlock Text="comprobante_pago.pdf" FontSize="11"
                                                               FontWeight="Medium" Foreground="White"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="1.2 MB" FontSize="10" Foreground="#99FFFFFF"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Thumb 4: Excel -->
                                    <Border Width="148" Height="148" CornerRadius="10" Margin="0,0,10,10"
                                            ClipToBounds="True" BorderBrush="#E5E7EB" BorderThickness="1"
                                            Cursor="Hand" Background="#F0FDF4">
                                        <Grid>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE80B;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="38" Foreground="#10B981" Opacity="0.7"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="XLSX" FontSize="11" FontWeight="Bold"
                                                           Foreground="#10B981" Opacity="0.6"
                                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                            </StackPanel>
                                            <Border Background="#10B981" CornerRadius="6" Padding="6,3"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Margin="0,8,8,0">
                                                <TextBlock Text="XLSX" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                            <Border VerticalAlignment="Bottom" Padding="10,16,10,8">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#00181818" Offset="0"/>
                                                        <GradientStop Color="#CC181818" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel>
                                                    <TextBlock Text="nota_remision.xlsx" FontSize="11"
                                                               FontWeight="Medium" Foreground="White"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="340 KB" FontSize="10" Foreground="#99FFFFFF"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Thumb 5: Video -->
                                    <Border Width="148" Height="148" CornerRadius="10" Margin="0,0,10,10"
                                            ClipToBounds="True" BorderBrush="#E5E7EB" BorderThickness="1"
                                            Cursor="Hand" Background="#FDF2F8">
                                        <Grid>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="38" Foreground="#EC4899" Opacity="0.7"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="MP4" FontSize="11" FontWeight="Bold"
                                                           Foreground="#EC4899" Opacity="0.6"
                                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                            </StackPanel>
                                            <Border Background="#EC4899" CornerRadius="6" Padding="6,3"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Margin="0,8,8,0">
                                                <TextBlock Text="MP4" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                            <Border VerticalAlignment="Bottom" Padding="10,16,10,8">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#00181818" Offset="0"/>
                                                        <GradientStop Color="#CC181818" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel>
                                                    <TextBlock Text="video_prueba.mp4" FontSize="11"
                                                               FontWeight="Medium" Foreground="White"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="45 MB" FontSize="10" Foreground="#99FFFFFF"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- === BARRA DE ACCIÓN: LIBERAR ORDEN === -->
                        <Border BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                                Padding="24,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="32" Height="32" CornerRadius="8" Background="#FFFBEB"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="&#xEA80;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14" Foreground="#F59E0B"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Archivos listos para revisión" FontSize="13"
                                                   FontWeight="Medium" Foreground="{StaticResource TextBody}"/>
                                        <TextBlock Text="Solicite la liberación para que el administrador revise y procese el pago."
                                                   FontSize="12" Foreground="{StaticResource TextMuted}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <Button Grid.Column="1" Style="{StaticResource BtnRelease}" Margin="20,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE785;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="#78350F" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="Liberar Orden" VerticalAlignment="Center"/>
                                        <TextBlock Text=" →" FontSize="16" Opacity="0.6" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================================= -->
            <!-- VARIANTE 2: DRAFT — SIN ARCHIVOS (BOTÓN OFF)  -->
            <!-- ============================================= -->
            <TextBlock Text="VARIANTE 2: SIN ARCHIVOS — BOTÓN DESHABILITADO" FontSize="11"
                       FontWeight="Bold" Foreground="{StaticResource TextLight}" Margin="0,0,0,10"
                      />

            <Border Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1"
                    Margin="0,0,0,30" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="1" Opacity="0.06" BlurRadius="8"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Fill="{StaticResource Danger}" RadiusX="2" RadiusY="2"/>

                    <StackPanel Grid.Column="1">
                        <!-- Header simplificado -->
                        <Grid Margin="24,20,24,16">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Orden: 7200045921" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextDark}"/>
                                <Border Background="#FEE2E2" CornerRadius="6" Padding="10,3" Margin="10,0,0,0">
                                    <TextBlock Text="Por completar" FontSize="12" FontWeight="Medium"
                                               Foreground="#991B1B"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="$2,100.00" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource TextDark}" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Estado vacío -->
                        <Border Background="{StaticResource BgGray}" BorderBrush="{StaticResource Border}"
                                BorderThickness="0,1,0,0" Padding="24,30">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="56" Height="56" CornerRadius="28"
                                        Background="{StaticResource PrimaryLight}"
                                        HorizontalAlignment="Center" Margin="0,0,0,12">
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="24" Foreground="{StaticResource Primary}" Opacity="0.6"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Sin facturas adjuntas" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Sube las facturas escaneadas para solicitar la liberación"
                                           FontSize="12" Foreground="{StaticResource TextLight}"
                                           HorizontalAlignment="Center" Margin="0,4,0,14"/>
                                <Button Style="{StaticResource BtnOutline}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                   Foreground="#5B3FF9" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Subir primera factura" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#5B3FF9" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Botón deshabilitado -->
                        <Border BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="24,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xEA80;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" Foreground="{StaticResource TextLight}"
                                               Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Suba las facturas firmadas para habilitar la liberación"
                                               FontSize="13" Foreground="{StaticResource TextLight}"/>
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource BtnRelease}"
                                        IsEnabled="False" Margin="20,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Suba facturas primero" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================================= -->
            <!-- VARIANTE 3: PENDING — ORDEN LIBERADA          -->
            <!-- ============================================= -->
            <TextBlock Text="VARIANTE 3: ORDEN LIBERADA — EN PROCESO DE PAGO (PENDING)" FontSize="11"
                       FontWeight="Bold" Foreground="{StaticResource TextLight}" Margin="0,0,0,10"
                      />

            <Border Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1"
                    Margin="0,0,0,30" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="1" Opacity="0.06" BlurRadius="8"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Fill="{StaticResource Amber}" RadiusX="2" RadiusY="2"/>

                    <StackPanel Grid.Column="1">
                        <Grid Margin="24,20,24,16">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Orden: 9000006318" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextDark}"/>
                                <Border Background="#FEF3C7" CornerRadius="6" Padding="10,3" Margin="10,0,0,0">
                                    <TextBlock Text="En proceso de pago" FontSize="12" FontWeight="Medium"
                                               Foreground="#92400E"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="$4,500.00" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource TextDark}" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Barra de estado liberada -->
                        <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="0,1,0,0"
                                Padding="24,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Badge -->
                                <Border Grid.Column="0" Background="White" CornerRadius="8"
                                        Padding="12,6" BorderBrush="#FDE68A" BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                   Foreground="#D97706" VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="Orden liberada — Procesando pago" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#92400E"/>
                                    </StackPanel>
                                </Border>

                                <!-- Info text -->
                                <TextBlock Grid.Column="1" Text="El administrador revisará los documentos y procesará el pago"
                                           FontSize="12" Foreground="#92400E" Opacity="0.7"
                                           VerticalAlignment="Center" Margin="16,0"/>

                                <!-- Progress steps -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Step 1: Done -->
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="22" CornerRadius="11" Background="#10B981">
                                            <TextBlock Text="✓" FontSize="11" FontWeight="Bold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Liberada" FontSize="11" Foreground="#065F46"
                                                   FontWeight="Medium" VerticalAlignment="Center" Margin="6,0"/>
                                    </StackPanel>
                                    <!-- Connector -->
                                    <Border Width="30" Height="2" Background="#D97706" VerticalAlignment="Center"
                                            Margin="6,0" CornerRadius="1"/>
                                    <!-- Step 2: Current -->
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="22" CornerRadius="11" Background="#F59E0B">
                                            <Border Width="10" Height="10" CornerRadius="5" Background="White"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Revisión admin" FontSize="11" Foreground="#92400E"
                                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0"/>
                                    </StackPanel>
                                    <!-- Connector -->
                                    <Border Width="30" Height="2" Background="#E2E8F0" VerticalAlignment="Center"
                                            Margin="6,0" CornerRadius="1"/>
                                    <!-- Step 3: Pending -->
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="22" CornerRadius="11" Background="White"
                                                BorderBrush="#E2E8F0" BorderThickness="2">
                                        </Border>
                                        <TextBlock Text="Pago" FontSize="11" Foreground="{StaticResource TextLight}"
                                                   VerticalAlignment="Center" Margin="6,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================================= -->
            <!-- VARIANTE 4: DRAG & DROP ZONE                  -->
            <!-- ============================================= -->
            <TextBlock Text="ZONA DE DRAG &amp; DROP (cuando el usuario arrastra archivos)" FontSize="11"
                       FontWeight="Bold" Foreground="{StaticResource TextLight}" Margin="0,0,0,10"
                      />

            <Border Height="180" CornerRadius="12" Margin="0,0,0,30">
                <Border.Background>
                    <SolidColorBrush Color="#5B3FF9" Opacity="0.04"/>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#5B3FF9"/>
                </Border.BorderBrush>
                <Border.BorderThickness>
                    <Thickness>2</Thickness>
                </Border.BorderThickness>
                <Border CornerRadius="12">
                    <!-- Dashed effect via inner styling -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="56" Height="56" CornerRadius="28"
                                Background="{StaticResource PrimaryLight}"
                                HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="24" Foreground="{StaticResource Primary}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Suelta tus archivos aquí" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource Primary}" HorizontalAlignment="Center"/>
                        <TextBlock Text="JPG, PNG, PDF — máx. 25 MB por archivo" FontSize="12"
                                   Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
