<Window x:Class="SistemaGestionProyectos2.Views.VendorDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mis Comisiones"
        Height="900" Width="1500"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal" WindowStyle="None" ResizeMode="NoResize">

    <Window.Resources>
        <!-- Colores unificados con SupplierPendingView -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#5B3FF9"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#48BB78"/>
        <SolidColorBrush x:Key="DangerColor" Color="#EF4444"/>
        <SolidColorBrush x:Key="WarningColor" Color="#F59E0B"/>
        <SolidColorBrush x:Key="InfoColor" Color="#3B82F6"/>
        <SolidColorBrush x:Key="BackgroundGray" Color="#F7FAFC"/>
        <SolidColorBrush x:Key="BorderGray" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextGray" Color="#718096"/>
        <SolidColorBrush x:Key="DarkText" Color="#2D3748"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundGray}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER (SupplierPendingView style) ===== -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderGray}"
                BorderThickness="0,0,0,1">
            <Grid Margin="30,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,16,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#5B3FF9" Offset="0"/>
                                <GradientStop Color="#764BA2" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Name="VendorInitials" Text="--" FontSize="20" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Name="VendorNameText" Text="Mis Comisiones" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource DarkText}"/>
                        <TextBlock Text="Panel de Vendedor" FontSize="14"
                                   Foreground="{StaticResource TextGray}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Click="LogoutButton_Click" Width="130" Height="36"
                            Background="White" BorderBrush="{StaticResource BorderGray}"
                            BorderThickness="1" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="←" FontSize="16" Margin="0,0,5,0"/>
                            <TextBlock Text="Cerrar Sesion"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== KPI CARDS (SupplierPendingView style) ===== -->
        <Grid Grid.Row="1" Margin="30,20,30,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,10,0" Padding="20,16" Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="1" Opacity="0.08" BlurRadius="4"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="🎯" FontSize="20" Margin="0,0,8,0"/>
                        <TextBlock Text="Por Completar" FontSize="13" Foreground="{StaticResource TextGray}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Name="TotalDraftText" Text="$0.00" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DangerColor}"/>
                    <TextBlock Name="DraftCountText" Text="0 ordenes" FontSize="12" Foreground="{StaticResource TextGray}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="5,0" Padding="20,16" Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="1" Opacity="0.08" BlurRadius="4"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="⏳" FontSize="20" Margin="0,0,8,0"/>
                        <TextBlock Text="En Proceso de Pago" FontSize="13" Foreground="{StaticResource TextGray}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Name="TotalPendingText" Text="$0.00" FontSize="28" FontWeight="Bold" Foreground="{StaticResource WarningColor}"/>
                    <TextBlock Name="PendingCountText" Text="0 ordenes" FontSize="12" Foreground="{StaticResource TextGray}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Margin="10,0,0,0" Padding="20,16" Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="1" Opacity="0.08" BlurRadius="4"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="✅" FontSize="20" Margin="0,0,8,0"/>
                        <TextBlock Text="Total Pagado" FontSize="13" Foreground="{StaticResource TextGray}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Name="TotalPaidText" Text="$0.00" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessColor}"/>
                    <TextBlock Name="PaidCountText" Text="0 ordenes" FontSize="12" Foreground="{StaticResource TextGray}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== COMMISSIONS LIST ===== -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Padding="30,20,30,20">
            <Grid>
                <ItemsControl Name="CommissionsItemsControl"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Card style matching SupplierPendingView -->
                            <Border Margin="0,0,0,15" Background="White" CornerRadius="12" Padding="0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="#6366F1"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Status bar lateral -->
                                    <Rectangle Grid.Column="0" RadiusX="2" RadiusY="2">
                                        <Rectangle.Style>
                                            <Style TargetType="Rectangle">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="draft">
                                                        <Setter Property="Fill" Value="{StaticResource DangerColor}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="pending">
                                                        <Setter Property="Fill" Value="{StaticResource WarningColor}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="paid">
                                                        <Setter Property="Fill" Value="{StaticResource SuccessColor}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                    </Rectangle>

                                    <StackPanel Grid.Column="1">
                                        <!-- TOP: Order info + amount -->
                                        <Grid Margin="20,20,24,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource DarkText}">
                                                        <Run Text="Orden: "/><Run Text="{Binding OrderNumber}"/>
                                                    </TextBlock>
                                                    <Border Margin="10,0,0,0" CornerRadius="6" Padding="10,3">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="draft">
                                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="pending">
                                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="paid">
                                                                        <Setter Property="Background" Value="#D1FAE5"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="12" FontWeight="Medium">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="draft">
                                                                            <Setter Property="Text" Value="Por completar"/>
                                                                            <Setter Property="Foreground" Value="#991B1B"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="pending">
                                                                            <Setter Property="Text" Value="En proceso de pago"/>
                                                                            <Setter Property="Foreground" Value="#92400E"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="paid">
                                                                            <Setter Property="Text" Value="Pagado"/>
                                                                            <Setter Property="Foreground" Value="#065F46"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Meta: Cliente + Detalle + Fecha (stacked vertical, bigger) -->
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Cliente:" FontSize="14" Foreground="{StaticResource TextGray}" FontWeight="Medium" Width="65"/>
                                                        <TextBlock Text="{Binding ClientName}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource DarkText}"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding OrderDescription}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding OrderDescription}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="Detalle:" FontSize="14" Foreground="{StaticResource TextGray}" FontWeight="Medium" Width="65"/>
                                                        <TextBlock Text="{Binding OrderDescription}" FontSize="14" FontWeight="Medium" Foreground="{StaticResource DarkText}" TextTrimming="CharacterEllipsis" MaxWidth="500"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="Fecha:" FontSize="14" Foreground="{StaticResource TextGray}" FontWeight="Medium" Width="65"/>
                                                        <TextBlock Text="{Binding OrderDate, StringFormat='{}{0:dd/MM/yyyy}'}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource DarkText}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Amount -->
                                            <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CommissionAmountFormatted}" FontSize="24" FontWeight="Bold"
                                                           Foreground="{StaticResource DarkText}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="Comision" FontSize="12" Foreground="{StaticResource TextGray}" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- FILES ZONE -->
                                        <Border Background="{StaticResource BackgroundGray}" BorderBrush="{StaticResource BorderGray}" BorderThickness="0,1,0,0" Padding="20,14">
                                            <StackPanel>
                                                <!-- Files header (toggle) -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Button Grid.Column="0" Tag="{Binding}" Click="ToggleFiles_Click"
                                                            Cursor="Hand" BorderThickness="0" HorizontalAlignment="Left"
                                                            ToolTip="Clic para ver o colapsar los archivos adjuntos">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="Transparent" CornerRadius="6"
                                                                        Padding="10,6" Margin="-10,-6" Name="ToggleBg">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="📎" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="Facturas y comprobantes" FontSize="13"
                                                                                   FontWeight="Medium" Foreground="{StaticResource TextGray}"
                                                                                   VerticalAlignment="Center" Name="ToggleLabel"/>
                                                                        <Border Background="{StaticResource BorderGray}" CornerRadius="10"
                                                                                Padding="7,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding FileCount, Mode=OneWay}" FontSize="11"
                                                                                       FontWeight="SemiBold" Foreground="{StaticResource TextGray}"/>
                                                                        </Border>
                                                                        <!-- Chevron -->
                                                                        <Border Background="White" CornerRadius="4" Width="22" Height="22"
                                                                                Margin="10,0,0,0" VerticalAlignment="Center"
                                                                                BorderBrush="{StaticResource BorderGray}" BorderThickness="1"
                                                                                Name="ChevronBg">
                                                                            <TextBlock FontSize="10" FontWeight="Bold"
                                                                                       Foreground="{StaticResource TextGray}"
                                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                       Name="ChevronIcon">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Text" Value="▼"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsFilesExpanded}" Value="True">
                                                                                                <Setter Property="Text" Value="▲"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Border>
                                                                    </StackPanel>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="ToggleBg" Property="Background" Value="#EDF2F7"/>
                                                                        <Setter TargetName="ToggleLabel" Property="Foreground" Value="{StaticResource DarkText}"/>
                                                                        <Setter TargetName="ChevronBg" Property="Background" Value="{StaticResource PrimaryColor}"/>
                                                                        <Setter TargetName="ChevronBg" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                                                        <Setter TargetName="ChevronIcon" Property="Foreground" Value="White"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>

                                                    <!-- Upload button (draft + pending, hidden when paid) -->
                                                    <Button Grid.Column="1" Tag="{Binding}" Click="UploadFile_Click" Cursor="Hand" BorderThickness="0">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="paid"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="#EDE9FE" CornerRadius="8" Padding="14,6"
                                                                        BorderBrush="{StaticResource PrimaryColor}" BorderThickness="1"
                                                                        Name="Bd">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="+" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,-2,6,0"/>
                                                                        <TextBlock Text="Subir archivos" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="#DDD6FE"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </Grid>

                                                <!-- Gallery (collapsible) -->
                                                <ItemsControl ItemsSource="{Binding Files}" Margin="0,12,0,0"
                                                              Visibility="{Binding IsFilesExpanded, Converter={StaticResource BoolToVis}}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="130" Height="130" CornerRadius="8"
                                                                    Background="White" BorderBrush="#E5E7EB" BorderThickness="1"
                                                                    Margin="0,0,10,10" ClipToBounds="True"
                                                                    Name="GalleryItem" Cursor="Hand">
                                                                <Grid>
                                                                    <!-- Placeholder -->
                                                                    <Border Background="{Binding PlaceholderColor}">
                                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                            <TextBlock Text="{Binding FileIcon}" FontSize="32" HorizontalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding FileExt}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextGray}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <!-- Image thumbnail -->
                                                                    <Image Source="{Binding ThumbnailSource, Mode=OneWay}" Stretch="UniformToFill"
                                                                           Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}"/>
                                                                    <!-- Bottom info -->
                                                                    <Border VerticalAlignment="Bottom" Padding="10,20,10,8">
                                                                        <Border.Background>
                                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                                <GradientStop Color="#00181818" Offset="0"/>
                                                                                <GradientStop Color="#D9181818" Offset="1"/>
                                                                            </LinearGradientBrush>
                                                                        </Border.Background>
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding FileName}" FontSize="11" FontWeight="Medium" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                                            <TextBlock Text="{Binding FileSizeFormatted}" FontSize="10" Foreground="#99FFFFFF" Margin="0,1,0,0"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <!-- Hover overlay -->
                                                                    <Border Name="Overlay" Background="#A618181B" Visibility="Collapsed">
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <Button Tag="{Binding}" Click="PreviewFile_Click" Cursor="Hand" BorderThickness="0" ToolTip="Ver" Margin="0,0,6,0">
                                                                                <Button.Template>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <Border Width="34" Height="34" CornerRadius="6" Background="#33FFFFFF" Name="Bb">
                                                                                            <TextBlock Text="👁" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bb" Property="Background" Value="#59FFFFFF"/></Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Button.Template>
                                                                            </Button>
                                                                            <Button Tag="{Binding}" Click="DownloadFileInline_Click" Cursor="Hand" BorderThickness="0" ToolTip="Descargar" Margin="0,0,6,0">
                                                                                <Button.Template>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <Border Width="34" Height="34" CornerRadius="6" Background="#B33B82F6" Name="Bb">
                                                                                            <TextBlock Text="⬇" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bb" Property="Background" Value="#E63B82F6"/></Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Button.Template>
                                                                            </Button>
                                                                            <Button Tag="{Binding}" Click="DeleteFileInline_Click" Cursor="Hand" BorderThickness="0" ToolTip="Eliminar"
                                                                                    Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}}">
                                                                                <Button.Template>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <Border Width="34" Height="34" CornerRadius="6" Background="#B3EF4444" Name="Bb">
                                                                                            <TextBlock Text="✕" FontSize="14" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bb" Property="Background" Value="#E6EF4444"/></Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Button.Template>
                                                                            </Button>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Grid>
                                                            </Border>
                                                            <DataTemplate.Triggers>
                                                                <Trigger SourceName="GalleryItem" Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Overlay" Property="Visibility" Value="Visible"/>
                                                                </Trigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Empty state -->
                                                <TextBlock Text="Sin archivos adjuntos" FontSize="12" Foreground="{StaticResource TextGray}" FontStyle="Italic"
                                                           Margin="0,8,0,0" Visibility="{Binding IsFilesExpanded, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasFiles}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!-- ACTION BAR: Solicitar Liberacion (draft + has files) -->
                                        <!-- TODO: Pendiente confirmacion admin - "Liberar" puede significar cambiar estado de la orden a LIBERADA(2) -->
                                        <Border BorderBrush="{StaticResource BorderGray}" BorderThickness="0,1,0,0" Padding="20,14">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding Status}" Value="draft"/>
                                                                <Condition Binding="{Binding HasFiles}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="💡" FontSize="14" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Suba las facturas firmadas y solicite la liberacion para procesar el pago." FontSize="12" Foreground="{StaticResource TextGray}"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Tag="{Binding}" Click="SolicitarLiberacion_Click"
                                                        Background="{StaticResource PrimaryColor}" Foreground="White"
                                                        BorderThickness="0" Cursor="Hand" Height="36">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="24,0">
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <TextBlock Text="Solicitar Liberacion" FontWeight="SemiBold"/>
                                                                    <TextBlock Text=" →" FontSize="14" Opacity="0.7"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.9"/></Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <!-- PENDING status row -->
                                        <Border BorderBrush="{StaticResource BorderGray}" BorderThickness="0,1,0,0" Padding="20,12">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="pending"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="#FEF3C7" CornerRadius="6" Padding="10,3">
                                                    <TextBlock Text="Procesando pago" FontSize="12" FontWeight="Medium" Foreground="#92400E"/>
                                                </Border>
                                                <Border Width="120" Height="4" Background="{StaticResource BorderGray}" CornerRadius="2" Margin="12,0" VerticalAlignment="Center">
                                                    <Border Background="{StaticResource WarningColor}" CornerRadius="2" Width="72" HorizontalAlignment="Left"/>
                                                </Border>
                                                <TextBlock Text="Pendiente de aprobacion" FontSize="12" Foreground="{StaticResource TextGray}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- No data -->
                <StackPanel Name="NoDataPanel" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,60,0,0" Visibility="Collapsed">
                    <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                    <TextBlock Name="NoDataTitle" Text="No hay comisiones" FontSize="18" Foreground="{StaticResource TextGray}" HorizontalAlignment="Center" Margin="0,20,0,5"/>
                    <TextBlock Name="NoDataMessage" Text="No se encontraron comisiones" FontSize="13" Foreground="{StaticResource TextGray}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ===== STATUS BAR ===== -->
        <Border Grid.Row="3" Background="{StaticResource DarkText}" Height="30">
            <Grid Margin="20,0">
                <TextBlock Text="Listo" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Name="StatusBarTime" Text="" Foreground="White" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
