<Window x:Class="SistemaGestionProyectos2.Views.EjecutorSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asignar Ejecutores"
        Width="400"
        Height="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Direction="270" ShadowDepth="6" Opacity="0.18"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#6366F1" CornerRadius="12,12,0,0" Padding="20,14">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="ASIGNAR EJECUTORES" FontSize="15" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock x:Name="OrderInfoText" Text="Orden: --"
                                   FontSize="11" Foreground="White" Opacity="0.8" Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Chips de seleccionados (preview) -->
            <Border Grid.Row="1" Margin="16,10,16,0" MinHeight="28">
                <ItemsControl x:Name="SelectedChipsPanel">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding ChipBackground}"
                                    CornerRadius="12" Padding="6,3,8,3" Margin="2,2">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="18" Height="18" CornerRadius="9"
                                            Background="{Binding ChipForeground}" Margin="0,0,5,0">
                                        <TextBlock Text="{Binding Initials}" FontSize="8"
                                                   FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding ShortName}" FontSize="11"
                                               Foreground="{Binding ChipForeground}"
                                               VerticalAlignment="Center" FontWeight="Medium"/>
                                    <Button Content="x" FontSize="10" Foreground="{Binding ChipForeground}"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" Margin="5,0,0,0" Padding="0"
                                            Click="RemoveChip_Click" Tag="{Binding}"
                                            VerticalAlignment="Center" Opacity="0.6"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Busqueda -->
            <Border Grid.Row="2" Margin="16,8,16,0" Background="#F9FAFB"
                    CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1">
                <Grid>
                    <TextBox x:Name="SearchBox" BorderThickness="0" Background="Transparent"
                             Padding="36,9,10,9" FontSize="13" VerticalAlignment="Center"
                             TextChanged="SearchBox_TextChanged"/>
                    <TextBlock Text="🔍" Margin="12,0,0,0" VerticalAlignment="Center"
                               Foreground="#9CA3AF" IsHitTestVisible="False"/>
                    <TextBlock Text="Buscar empleado..." Margin="36,0,0,0"
                               VerticalAlignment="Center" Foreground="#9CA3AF"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Hidden"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text.Length, ElementName=SearchBox}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Lista de empleados -->
            <Border Grid.Row="3" Margin="16,8,16,0">
                <ListBox x:Name="EmployeeListBox" BorderThickness="0" Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent"
                                                CornerRadius="8" Padding="8,6" Margin="0,1">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#F9FAFB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Cursor="Hand"
                                  MouseLeftButtonDown="EmployeeItem_Click"
                                  Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Avatar -->
                                <Border Grid.Column="0" Width="32" Height="32"
                                        CornerRadius="16" Margin="0,0,10,0"
                                        Background="{Binding AvatarBackground}">
                                    <TextBlock Text="{Binding Initials}"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Nombre y cargo -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding EmployeeName}" FontSize="13"
                                               Foreground="#1F2937" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding Title}" FontSize="10.5"
                                               Foreground="#9CA3AF" Margin="0,1,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Title}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Check indicator -->
                                <Border Grid.Column="2" Width="22" Height="22"
                                        CornerRadius="11" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F3F4F6"/>
                                            <Setter Property="BorderBrush" Value="#D1D5DB"/>
                                            <Setter Property="BorderThickness" Value="1.5"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#6366F1"/>
                                                    <Setter Property="BorderBrush" Value="#6366F1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="✓" FontSize="12" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Footer -->
            <Grid Grid.Row="4" Margin="16,10,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="SelectionCountText" Grid.Column="0"
                           Text="0 seleccionados" FontSize="12" Foreground="#6B7280"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="2" Content="Cancelar" Click="CancelButton_Click"
                        Width="85" Height="34" Margin="0,0,8,0"
                        Background="White" Foreground="#374151"
                        BorderBrush="#D1D5DB" BorderThickness="1"
                        FontSize="13" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F3F4F6"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="3" Content="Guardar" Click="SaveButton_Click"
                        Width="85" Height="34"
                        Background="#6366F1" Foreground="White"
                        BorderThickness="0" FontSize="13" FontWeight="SemiBold"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
